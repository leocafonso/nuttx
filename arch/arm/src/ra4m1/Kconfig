comment "RA4M1 Configuration Options"

choice
	prompt "RA4M1 Chip Selection"
	default ARCH_CHIP_R7FA4M1ABxxFP
	depends on ARCH_CHIP_RA4M1

config ARCH_CHIP_R7FA4M1ABxxFP 
	bool "R7FA4M1ABxxFP"
	select ARCH_CORTEXM4

endchoice # RA4M1 Chip Selection